          "hide": false,
          "query": "from(bucket: \"lora_bucket\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  // Es muy recomendable agregar el _measurement, a veces Grafana falla si no está\n  |> filter(fn: (r) => r[\"_measurement\"] == \"mqtt_consumer\") \n  // Usa el campo exacto de tu contador (en nodos LoRa suele llamarse fCnt, fcnt_up o similar)\n  |> filter(fn: (r) => r[\"_field\"] == \"f_cnt\")\n  |> difference(nonNegative: true)\n  // restar un paquete para reflejar la realidad\n  |> map(fn: (r) => ({ r with _value: r._value - 1 }))",
